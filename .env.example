# Nests Production Configuration
# Copy to .env and update with your domains

# Frontend domain (served by nests-web on port 8080, put behind reverse proxy for HTTPS)
NESTS_DOMAIN=nests.example.com

# MoQ relay domain (WebTransport — needs real TLS certs in ./certs/)
MOQ_RELAY_DOMAIN=moq.nests.example.com
MOQ_RELAY_PORT=4443

# MoQ auth service domain (put behind reverse proxy for HTTPS)
MOQ_AUTH_DOMAIN=moq-auth.nests.example.com
